---
export interface Props {
  buttonId: string;
}

const { buttonId } = Astro.props;
---

<div id="glass-zoom-overlay" class="zoom-layer" data-btn={buttonId}>
  <!-- Clone will be injected directly here -->
</div>

<div id="glass-lens-ring" class="lens-ring"></div>

<style>
  .zoom-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    clip-path: circle(0px at 50% 50%);
    -webkit-clip-path: circle(0px at 50% 50%);
    z-index: 50;
    overflow: hidden;

    /* Solid white blocks the unscaled text from showing through */
    background-color: #ffffff;
  }

  .lens-ring {
    position: absolute;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 51;
    opacity: 0;

    /* Clips the inner shimmer and fog */
    overflow: hidden;
    box-sizing: border-box;

    /* VERY soft frosty inner edge */
    background: radial-gradient(
      circle at 50% 50%,
      rgba(255, 255, 255, 0) 60%,
      rgba(240, 248, 255, 0.05) 80%,
      rgba(255, 255, 255, 0.35) 100%
    );

    /* Thinner, softer border */
    border: 1px solid rgba(255, 255, 255, 0.7);

    /* Animates soft white/blue inner glows and a subtle dark drop shadow */
    animation: gentle-glow 4s ease-in-out infinite;

    &::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0) 40%,
        rgba(255, 255, 255, 0.6) 50%,
        rgba(255, 255, 255, 0) 60%,
        rgba(255, 255, 255, 0) 100%
      );
      /* Slowed down glare */
      animation: glass-glare 6s infinite linear;
    }
  }

  @keyframes gentle-glow {
    0%,
    100% {
      box-shadow:
        inset 0 4px 15px rgba(255, 255, 255, 0.8),
        inset 0 -4px 15px rgba(220, 240, 255, 0.3),
        0 8px 24px rgba(0, 0, 0, 0.04),
        /* Subtle dark drop shadow */ 0 0 10px rgba(200, 235, 255, 0.15); /* Ultra-soft blue outer halo */
    }
    50% {
      box-shadow:
        inset 0 4px 15px rgba(255, 255, 255, 0.9),
        inset 0 -4px 20px rgba(220, 240, 255, 0.5),
        0 12px 32px rgba(0, 0, 0, 0.06),
        /* Slightly deeper shadow */ 0 0 20px rgba(200, 235, 255, 0.25);
    }
  }

  @keyframes glass-glare {
    0% {
      transform: translateY(-100%) rotate(45deg);
    }
    20% {
      transform: translateY(100%) rotate(45deg);
    }
    100% {
      transform: translateY(100%) rotate(45deg);
    }
  }

  :global(.hide-cursor) {
    cursor: none !important;
  }
</style>

<script>
  function initGlassZoom() {
    const overlay = document.getElementById("glass-zoom-overlay");
    const lensRing = document.getElementById("glass-lens-ring");

    if (!overlay || !lensRing) return;

    // Strictly targets #initial
    const target = document.getElementById("initial");
    const btn = document.getElementById(overlay.dataset.btn);

    if (!target || !btn || target.dataset.zoomInitialized) return;
    target.dataset.zoomInitialized = "true";
    target.style.position = "relative";

    // Deep clone #initial
    const clone = target.cloneNode(true);
    clone.id = "";

    // Remove tool artifacts from the clone
    clone
      .querySelectorAll(".zoom-layer, .lens-ring")
      .forEach((el) => el.remove());

    // Lock clone dimensions & styling to match original precisely
    clone.style.position = "absolute";
    clone.style.top = "0";
    clone.style.left = "0";
    clone.style.margin = "0";
    clone.style.border = "none";
    clone.style.width = `${target.clientWidth}px`;
    clone.style.height = `${target.clientHeight}px`;
    clone.style.boxSizing = "border-box";
    clone.style.transformOrigin = "0 0";
    clone.style.willChange = "transform-origin, transform";

    // Inject clone into overlay
    overlay.innerHTML = "";
    overlay.appendChild(clone);

    // Append overlay and ring to #initial
    target.appendChild(overlay);
    target.appendChild(lensRing);

    // Interaction Variables
    const LENS_MAX_RADIUS = 150;
    const SPRING_TENSION = 0.15;
    const SPRING_FRICTION = 0.75;

    let isActive = false;
    let targetRadius = 0,
      currentRadius = 0,
      radiusVelocity = 0;
    let currentX = target.offsetWidth / 2,
      currentY = target.offsetHeight / 2;
    let mouseX = currentX,
      mouseY = currentY;

    btn.addEventListener("click", () => {
      isActive = !isActive;
      targetRadius = isActive ? LENS_MAX_RADIUS : 0;
      btn.textContent = isActive ? "Disable Magnifier" : "Enable Magnifier";

      if (isActive) {
        currentX = target.offsetWidth / 2;
        currentY = target.offsetHeight / 2;
        mouseX = currentX;
        mouseY = currentY;
      } else {
        target.classList.remove("hide-cursor");
      }
    });

    target.addEventListener("mouseenter", () => {
      if (isActive) target.classList.add("hide-cursor");
    });

    target.addEventListener("mouseleave", () => {
      target.classList.remove("hide-cursor");
    });

    target.addEventListener("mousemove", (e) => {
      if (!isActive) return;

      const rect = target.getBoundingClientRect();
      const style = window.getComputedStyle(target);
      const borderLeft = parseFloat(style.borderLeftWidth) || 0;
      const borderTop = parseFloat(style.borderTopWidth) || 0;

      mouseX = e.clientX - rect.left - borderLeft;
      mouseY = e.clientY - rect.top - borderTop;

      target.classList.add("hide-cursor");
    });

    function animate() {
      // Fluid physics
      radiusVelocity += (targetRadius - currentRadius) * SPRING_TENSION;
      radiusVelocity *= SPRING_FRICTION;
      currentRadius += radiusVelocity;

      const safeRadius = Math.max(0, currentRadius);
      currentX += (mouseX - currentX) * 0.15;
      currentY += (mouseY - currentY) * 0.15;

      // Calculate animation progress (0.0 to 1.0)
      const progress = Math.min(Math.max(safeRadius / LENS_MAX_RADIUS, 0), 1);

      // Smoothly fade everything in and out
      lensRing.style.opacity = progress;
      overlay.style.opacity = progress;

      // Dynamic zooming: Animates from 1.0x to 1.5x as it opens
      const currentScale = 1.0 + 0.5 * progress;
      clone.style.transform = `scale(${currentScale})`;

      // Update clipping masks
      const clipString = `circle(${safeRadius}px at ${currentX}px ${currentY}px)`;
      overlay.style.clipPath = clipString;
      overlay.style.webkitClipPath = clipString;

      // Scale from exact mouse coordinates
      clone.style.transformOrigin = `${currentX}px ${currentY}px`;

      // Position the glowing lens ring
      Object.assign(lensRing.style, {
        width: `${safeRadius * 2}px`,
        height: `${safeRadius * 2}px`,
        left: `${currentX}px`,
        top: `${currentY}px`,
      });

      requestAnimationFrame(animate);
    }

    animate();
  }

  document.addEventListener("DOMContentLoaded", initGlassZoom);
  document.addEventListener("astro:page-load", initGlassZoom);
</script>
