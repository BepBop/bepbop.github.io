              <li>GTM Strategy, Product Launch, Customer Adoption Metrics</li>
            </ul>
          </div>
        </div>

        <!-- ACHIEVEMENTS SECTION -->
        <div class="content-layout__main-panel-header">
          <span>Achievements</span>
        </div>

        <div class="content-layout__main-panel-content">
          <div class="content-layout__main-panel-content-left">
            <span style="font-weight: 500;">Double Promotion</span>
          </div>
          <div class="content-layout__main-panel-content-right">
            <ul style="margin-bottom: 0;">
              <li>
                Achieved rapid promotions by consistently exceeding product
