---
import { ClientRouter } from "astro:transitions";
import Timeline from "../components/molecules/Timeline";
const title = "Gyan Anjay's Portfolio | Jobs, Projects and Skills";
const description =
  "Explore Gyan Anjay's portfolio showcasing professional projects, skills, and achievements. Discover how I can contribute to your team's success.";
const baseUrl = "https://bepbop.github.io/2025";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Basic SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={baseUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={baseUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/icon.svg" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/icon.svg" />

    <!-- Icons -->
    <link rel="shortcut icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="apple-touch-icon" href="/icon.svg" />

    <!-- Stylesheets -->
    <link rel="stylesheet" href="/css/Root.css" />

    <!-- Theme -->
    <meta name="theme-color" content="#fafafa" />

    <!-- Enhanced Structured Data for Portfolio -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        "mainEntity": {
          "@type": "Person",
          "name": "Gyan Anjay",
          "description": "Software Developer and Technology Professional",
          "url": "https://bepbop.github.io",
          "sameAs": [
            "https://linkedin.com/in/gyananjay",
            "https://github.com/bepbop"
          ],
          "jobTitle": "Software Developer",
          "knowsAbout": [
            "Software Development",
            "Web Development",
            "JavaScript",
            "React",
            "Node.js"
          ],
          "image": "/icon.svg"
        }
      }
    </script>

    <ClientRouter />
  </head>
  <body class="margin">
    <Timeline client:only="react" transition:name="trans" transition:persist />

    <header id="section-1-2025">
      <div>
        <h1>Gyan Anjay</h1>
        <h2>Associate Product Manager 2</h2>
      </div>
      <button aria-pressed="false">
        Click Me
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          style="transform: rotate(-10deg); margin-left:8px"
        >
          <!-- Perfect geometric classic cursor -->
          <path d="M5 2V22L10 17L14 24L17 22L13 15H19L5 2Z" fill="currentColor"
          ></path>
        </svg>
      </button>
    </header>

    <main id="section-2-2025" class="content-layout">
      <aside class="content-layout__sidebar">
        <div class="info-card">
          <ul class="tag-list">
            <li>CRM</li>
            <li>B2B</li>
            <li>SaaS</li>
            <li>Startup</li>
          </ul>
          <p class="info-card__description">
            APM II with a proven background in a B2B SaaS CRM startup,
            contributing to early-stage product development.
          </p>
        </div>

        <div class="contact-links">
          <a href="mailto:anjaygyan@gmail.com" class="contact-links__item">
            <span>anjaygyan@gmail.com</span>
            <img src="/img/arrow.svg" alt="Arrow icon" />
          </a>
          <a
            href="https://www.linkedin.com/in/anjaygyan/"
            class="contact-links__item"
          >
            <span>LinkedIn</span>
            <img src="/img/arrow.svg" alt="Arrow icon" />
          </a>
          <a
            href="https://github.com/BepBop/Reading_Listing_Manager"
            class="contact-links__item"
          >
            <span>My Github Repo / AI Vibe Coded App </span>
            <img src="/img/arrow.svg" alt="Arrow icon" />
          </a>
        </div>
      </aside>

      <section class="content-layout__main-panel" id="initial">
        <div class="content-layout__main-panel-header">
          <span> Experience</span>
        </div>

        <div class="content-layout__main-panel-content">
          <div class="content-layout__main-panel-content-left">
            <span style="font-weight: 500;"> Associate Product Manager 2</span>
            <p>LeadSquared</p>
            <p>October 2024 - Present</p>
